/var/log/openvpn/*.log {
	daily
	rotate 7
	compress
	missingok
	copy
	notifempty
	dateext
	dateformat -%Y-%m-%d-daily
}

/var/log/openvpn/*.log {
        weekly
        rotate 52
        compress
        missingok
        copytruncate
        notifempty
        dateext
        dateformat -%Y-%m-%d-weekly
}

